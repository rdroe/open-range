# Publishing model: package.json "files" is the allowlist — currently only `dist/`
# (built JS + declarations for the public API in src/lib/index.ts and subpath types).
# This file excludes everything else so the tarball stays minimal even if "files" changes.
#
# npm still includes README and package.json by default for the registry listing.

# Source, demos, and app shells (not part of the published library)
src/
tests/
e2e/
site/
index.html
mock-data-demo.html
library-harness.html

# Tooling & config
*.config.*
tsconfig*.json
.yarnrc.yml
.yarn/
.pnp.cjs
.pnp.loader.mjs
yarn.lock

# CI / editor (if present)
.github/
.cursor/

# Logs, caches, artifacts
*.log
coverage/
test-results/
playwright-report/
playwright/.cache/
node_modules/

# Misc
.DS_Store
.git/
.gitignore
.editorconfig
